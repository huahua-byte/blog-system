{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "types": [
      "node"
    ],
    "baseUrl": "."
  },
  "include": [
    "docs/.vitepress/**/*.ts",
    "docs/.vitepress/**/*.d.ts",
    "components/**/*.ts",
    "components/**/*.d.ts"
  ],
  "exclude": [
    "docs/.vitepress/dist",
    "node_modules"
  ]
}
